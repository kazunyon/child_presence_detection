# Never commit real values. Configure these in Render / GitHub Actions secrets.
DATABASE_URL=postgresql+psycopg://user:password@host:5432/mamoru_bus
JWT_SECRET=replace-with-a-long-random-secret
TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=https://kazunyon.github.io
ENVIRONMENT=production
VITE_API_BASE_URL=https://your-api.onrender.com
# Set this only after a notification provider or integration endpoint is ready.
NOTIFICATION_WEBHOOK_URL=https://example.com/mamoru-bus-webhook
# In production, point to encrypted persistent object storage mounted by the platform.
UPLOAD_DIR=/var/data/mamoru-bus-uploads