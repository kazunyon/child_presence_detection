# Never commit real values. Configure these in Render / GitHub Actions secrets.
DATABASE_URL=postgresql+psycopg://user:password@host:5432/mamoru_bus
JWT_SECRET=replace-with-a-long-random-secret
TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=https://kazunyon.github.io
ENVIRONMENT=production
VITE_API_BASE_URL=https://your-api.onrender.com
# LINE Messaging API. Never expose these values to the browser.
LINE_CHANNEL_ACCESS_TOKEN=replace-with-line-channel-access-token
LINE_CHANNEL_SECRET=replace-with-line-channel-secret
# The organization ID which owns this LINE Official Account. Use 1 only for fresh development data.
LINE_ORGANIZATION_ID=1
# Retained for non-LINE webhook notifications.
NOTIFICATION_WEBHOOK_URL=https://example.com/mamoru-bus-webhook
UPLOAD_DIR=/var/data/mamoru-bus-uploads